# JWT — must match ambivo_api cookie_secret
JWT_SECRET_KEY=your_jwt_secret_here
JWT_ALGORITHM=HS256

# MongoDB
MONGODB_URL=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DATABASE=omnilonely

# VectorDB API
VECTORDB_API_URL=https://vectordbapi.ambivo.com
AMBIVO_INTERNAL_SECRET=your_internal_secret_here

# Ambivo API (login proxy)
AMBIVO_API_URL=https://goferapi.ambivo.com

# App
HOST=0.0.0.0
PORT=8003
DAILY_CHAT_LIMIT=20

# AI page generation (Anthropic Claude)
ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL=claude-sonnet-4-20250514
DEBUG=false
LOG_LEVEL=INFO
